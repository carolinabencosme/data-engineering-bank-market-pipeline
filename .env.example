# ---------- Global ----------
COMPOSE_PROJECT_NAME=bank-market
ENVIRONMENT=dev
LOG_LEVEL=INFO

# ---------- Postgres ----------
POSTGRES_IMAGE_TAG=16-alpine
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=bank_market
POSTGRES_USER=pipeline
POSTGRES_PASSWORD=change_me
POSTGRES_PGDATA=/var/lib/postgresql/data/pgdata

# ---------- ClickHouse ----------
CLICKHOUSE_IMAGE_TAG=24.8
CLICKHOUSE_HOST=clickhouse
CLICKHOUSE_HTTP_PORT=8123
CLICKHOUSE_NATIVE_PORT=9000
CLICKHOUSE_DB=bank_market
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=change_me
# Airflow OLAP bulk INSERT (many distinct YYYYMM partitions); default 100 is too low for ratings/history backfills.
CLICKHOUSE_MAX_PARTITIONS_PER_INSERT_BLOCK=10000

# ---------- Airbyte integration (optional) ----------
# Airbyte is provisioned with abctl (not in docker-compose). Use for API scripts / health checks.
AIRBYTE_API_BASE_URL=http://localhost:8000/api/public/v1
AIRBYTE_API_TIMEOUT_SECONDS=30

# ---------- Pipeline extract / landing (Airflow tasks) ----------
# Comma-separated tickers; if empty, Yahoo screener universe is used (see PIPELINE_BANK_UNIVERSE_LIMIT).
PIPELINE_YAHOO_SYMBOLS=JPM,BAC,WFC,C,GS,MS
PIPELINE_BANK_UNIVERSE_LIMIT=3
PIPELINE_EXTRACT_START_DATE=2024-01-01
PIPELINE_EXTRACT_END_DATE=2025-12-31
PIPELINE_YAHOO_BATCH_SIZE=2
PIPELINE_YAHOO_BATCH_PAUSE_SECONDS=2
# When Yahoo quoteSummary fails (common from datacenter IPs), use yfinance as fallback (requires yfinance in Airflow image).
PIPELINE_YFINANCE_FALLBACK=1
PIPELINE_SOURCE_SYSTEM=yahoo_finance
# Writable directory inside Airflow containers for extract->load handoff (default matches compose volume).
PIPELINE_XCOM_SCRATCH_DIR=/opt/airflow/dags/_pipeline_scratch
# Airflow connection id used by PostgresHook for landing (must exist or use URI below).
AIRFLOW__PIPELINE__LANDING_CONN_ID=postgres_landing
# Optional: connection URI for Airflow env-style connection postgres_landing (same host as pipeline DB).
AIRFLOW_CONN_POSTGRES_LANDING=postgresql://pipeline:change_me@postgres:5432/bank_market
# Connection id referenced in DAG logs / future ClickHouseHook use (optional today; loader uses CLICKHOUSE_* env).
AIRFLOW__PIPELINE__OLAP_CONN_ID=clickhouse_olap
# Cron for DAG desacoplado landing -> OLAP (solo si usas bank_market_landing_to_olap).
AIRFLOW__PIPELINE__LANDING_TO_OLAP_CRON=*/30 * * * *

# ---------- Airflow ----------
# Metadata DB (separate from POSTGRES_DB / pipeline landing).
AIRFLOW_IMAGE_TAG=2.11.2
AIRFLOW_HOST=airflow
AIRFLOW_WEBSERVER_PORT=8080
AIRFLOW_UID=50000
AIRFLOW_EXECUTOR=LocalExecutor
AIRFLOW_DB_HOST=postgres
AIRFLOW_DB_PORT=5432
AIRFLOW_DB_NAME=airflow
AIRFLOW_DB_USER=airflow
AIRFLOW_DB_PASSWORD=change_me
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://airflow:change_me@postgres:5432/airflow
AIRFLOW__CORE__FERNET_KEY=replace_with_fernet_key
AIRFLOW__WEBSERVER__SECRET_KEY=replace_with_web_secret
AIRFLOW_ADMIN_USERNAME=admin
AIRFLOW_ADMIN_FIRSTNAME=Admin
AIRFLOW_ADMIN_LASTNAME=User
AIRFLOW_ADMIN_EMAIL=admin@example.com
AIRFLOW_ADMIN_PASSWORD=change_me
# DAG default_args (notificaciones / resiliencia)
AIRFLOW_ALERT_EMAIL=admin@example.com
AIRFLOW_TASK_RETRIES=2
AIRFLOW_TASK_RETRY_DELAY_MINUTES=5
AIRFLOW_TASK_TIMEOUT_MINUTES=45

# ---------- dbt ----------
DBT_IMAGE_TAG=1.8.latest
DBT_DB_HOST=postgres
DBT_DB_PORT=5432
DBT_DB_USER=pipeline
DBT_DB_PASSWORD=change_me
DBT_DB_NAME=bank_market
DBT_DB_SCHEMA=analytics
DBT_THREADS=4
# dbt runtime paths for Airflow BashOperator tasks (writeable inside container).
DBT_PROJECT_DIR=/opt/airflow/dbt
DBT_PROFILES_DIR=/opt/airflow/infra/dbt
DBT_LOG_PATH=/tmp/dbt/logs
DBT_TARGET_PATH=/tmp/dbt/target
DBT_PACKAGES_INSTALL_PATH=/tmp/dbt/dbt_packages
# dbt target `olap` (ClickHouse). En Compose, airflow/dbt suelen tomar CLICKHOUSE_*; estas líneas sirven también si ejecutas dbt fuera de Compose apuntando a localhost.
DBT_CH_HOST=clickhouse
DBT_CH_HTTP_PORT=8123
DBT_CH_USER=default
DBT_CH_PASSWORD=change_me
DBT_CH_DATABASE=olap
# Ventana del mart mensual en ClickHouse (alinear con PIPELINE_EXTRACT_* cuando aplique).
PIPELINE_MART_START_DATE=2024-01-01
PIPELINE_MART_END_DATE=2025-12-31

# ---------- Airflow webserver stability for local Docker ----------
AIRFLOW__WEBSERVER__WEB_SERVER_MASTER_TIMEOUT=300
AIRFLOW__WEBSERVER__WEB_SERVER_WORKER_TIMEOUT=300
AIRFLOW__WEBSERVER__WORKERS=2
AIRFLOW__CORE__LOAD_EXAMPLES=False

# ---------- scripts/check-health.* (Airflow webserver /health; opcional) ----------
# Espera hasta que /health responda "healthy" o hasta MAX_WAIT_SECONDS (reintenta cada SLEEP_SECONDS).
# Si cargas este .env en el shell antes del script, el script usará estos valores.
HEALTHCHECK_AIRFLOW_WEBSERVER_MAX_WAIT_SECONDS=1800
HEALTHCHECK_AIRFLOW_WEBSERVER_SLEEP_SECONDS=5
