# Optional Airflow-specific overrides (merged after project root .env).
# Required keys such as AIRFLOW__DATABASE__SQL_ALCHEMY_CONN, AIRFLOW__CORE__FERNET_KEY,
# AIRFLOW__WEBSERVER__SECRET_KEY, and admin credentials must be set in the project .env.
# Docker Compose does not expand ${VAR} inside env_file values.

AIRFLOW__CORE__LOAD_EXAMPLES=False
